import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
        Scanner sc=new Scanner(System.in);
        int N=sc.nextInt();
        int A=sc.nextInt();
	    int B=sc.nextInt();
	    int tot=A*B;
	    int bal=N-tot;
	    System.out.println(bal);
	}
}
